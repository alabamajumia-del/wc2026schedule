# AdSense verification infrastructure
# Keep these empty/off until a real AdSense account provides the publisher ID.

# Example format only. Do not use this placeholder in production.
ADSENSE_PUBLISHER_ID=

# Verification method options:
# off   = no AdSense verification tag is injected
# meta  = inject <meta name="google-adsense-account" content="ca-pub-...">
# code  = inject the AdSense code snippet only when ADSENSE_ENABLE_SCRIPT=true
# both  = inject meta and code snippet, with code snippet still gated by ADSENSE_ENABLE_SCRIPT=true
ADSENSE_VERIFICATION_METHOD=off

# Keep false in local preview and normal development builds.
ADSENSE_ENABLE_SCRIPT=false

# Keep false until the official AdSense ads.txt line is available.
ADSENSE_ENABLE_ADS_TXT=false
